ng-t81wn-ejs9u\")\nversion = project.version(1)\ndataset = version.download(\"yolov8\")\n\nprint(f\"\\n✅ Dataset downloaded successfully to: {dataset.location}\")\ndataset_path = Path(dataset.location)\nprint(f\"Dataset location: {dataset_path}\")\n\n# Step 4: Check and Fix Dataset Structure\nprint(\"\\n\" + \"=\"*50)\nprint(\"Checking and Fixing Dataset Structure\")\nprint(\"=\"*50)\n\n# List contents\nprint(\"\\nCurrent directory structure:\")\nfor item in dataset_path.iterdir():\n    if item.is_dir():\n        print(f\"  📁 {item.name}/\")\n        # Check subdirectories\n        for subitem in item.iterdir():\n            if subitem.is_dir():\n                print(f\"      📁 {subitem.name}/\")\n            elif subitem.is_file():\n                print(f\"      📄 {subitem.name}\")\n\n# The dataset only has train folder with images and labels\ntrain_dir = dataset_path / 'train'\nif train_dir.exists():\n    print(f\"\\n✅ Found training data at: {train_dir}\")\n    train_images = list((train_dir / 'images').glob('*.*'))\n    print(f\"   Training images: {len(train_images)}\")\n    \n    # Check if we need to create validation set\n    valid_dir = dataset_path / 'valid'\n    if not valid_dir.exists() or len(list((valid_dir / 'images').glob('*.*'))) == 0:\n        print(\"\\n⚠️ Validation set missing or empty. Creating train/validation split...\")\n        \n        # Create temporary directory with proper structure for split\n        temp_dir = dataset_path / 'temp_split'\n        temp_dir.mkdir(exist_ok=True)\n        \n        # Copy images and labels to temp directory in the format expected by split-folders\n        # split-folders expects: input_dir/class1/, input_dir/class2/, etc.\n        # But for object detection, we need a different approach\n        \n        # Better approach: Manual split\n        # Create validation directory\n        valid_dir = dataset_path / 'valid'\n        valid_dir.mkdir(exist_ok=True)\n        (valid_dir / 'images').mkdir(parents=True, exist_ok=True)\n        (valid_dir / 'labels').mkdir(parents=True, exist_ok=True)\n        \n        # Get all training images\n        train_images = list((train_dir / 'images').glob('*.*'))\n        \n        # Shuffle and split 80-20\n        random.shuffle(train_images)\n        split_idx = int(0.8 * len(train_images))\n        val_images = train_images[split_idx:]\n        train_images = train_images[:split_idx]\n        \n        print(f\"\\n   Splitting {len(train_images) + len(val_images)} total images:\")\n        print(f\"   New training set: {len(train_images)} images\")\n        print(f\"   Validation set: {len(val_images)} images\")\n        \n        # Move validation images and corresponding labels\n        for img_path in val_images:\n            # Move image\n            dest_img = valid_dir / 'images' / img_path.name\n            shutil.move(str(img_path), str(dest_img))\n            \n            # Move corresponding label\n            label_path = train_dir / 'labels' / f\"{img_path.stem}.txt\"\n            if label_path.exists():\n                dest_label = valid_dir / 'labels' / f\"{img_path.stem}.txt\"\n                shutil.move(str(label_path), str(dest_label))\n        \n        print(\"✅ Train/validation split complete!\")\n    else:\n        print(f\"\\n✅ Validation set exists with {len(list((valid_dir / 'images').glob('*.*')))} images\")\nelse:\n    print(\"\\n❌ Train directory not found!\")\n\n# Step 5: Create test directory if it doesn't exist\ntest_dir = dataset_path / 'test'\nif not test_dir.exists():\n    test_dir.mkdir(exist_ok=True)\n    (test_dir / 'images').mkdir(parents=True, exist_ok=True)\n    (test_dir / 'labels').mkdir(parents=True, exist_ok=True)\n    print(\"\\n✅ Created test directory (will be empty - no test data available)\")\n\n# Step 6: Update YAML paths correctly\nprint(\"\\n\" + \"=\"*50)\nprint(\"Updating Dataset Configuration\")\nprint(\"=\"*50)\n\nyaml_path = dataset_path / \"data.yaml\"\nwith open(yaml_path, 'r') as f:\n    data_config = yaml.safe_load(f)\n\nprint(f\"\\nOriginal dataset configuration:\")\nprint(f\"  Number of classes: {data_config['nc']}\")\nprint(f\"  Class names: {data_config['names']}\")\n\n# Update paths to absolute paths for Kaggle\nbase_path = str(dataset_path.absolute())\ndata_config['path'] = base_path\ndata_config['train'] = str(dataset_path / 'train' / 'images')\ndata_config['val'] = str(dataset_path / 'valid' / 'images')\ndata_config['test'] = str(dataset_path / 'test' / 'images')\n\n# Save updated config\nwith open(yaml_path, 'w') as f:\n    yaml.dump(data_config, f, default_flow_style=False)\n\nprint(f\"\\n✅ Updated paths in data.yaml:\")\nprint(f\"  Base path: {data_config['path']}\")\nprint(f\"  Train path: {data_config['train']}\")\nprint(f\"  Val path: {data_config['val']}\")\nprint(f\"  Test path: {data_config['test']}\")\n\n# Verify paths exist\nprint(\"\\nVerifying paths:\")\ntrain_images = Path(data_config['train'])\nval_images = Path(data_config['val'])\n\nprint(f\"  Train images exist: {train_images.exists()}\")\nprint(f\"  Val images exist: {val_images.exists()}\")\n\nif train_images.exists():\n    train_img_count = len(list(train_images.glob('*.*')))\n    print(f\"  Train images count: {train_img_count}\")\nif val_images.exists():\n    val_img_count = len(list(val_images.glob('*.*')))\n    print(f\"  Val images count: {val_img_count}\")\n\n# Step 7: Data Visualization and Analysis\nprint(\"\\n\" + \"=\"*50)\nprint(\"Data Visualization and Analysis\")\nprint(\"=\"*50)\n\ndef analyze_dataset(data_path):\n    \"\"\"Analyze and visualize dataset statistics\"\"\"\n    \n    splits = ['train', 'valid', 'test']\n    split_counts = {}\n    \n    for split_name in splits:\n        split_path = data_path / split_name / 'images'\n        if split_path.exists():\n            images = list(split_path.glob('*.*'))\n            split_counts[split_name] = len(images)\n            print(f\"\\n{split_name.capitalize()} set: {len(images)} images\")\n            \n            # Show sample images if available\n            if len(images) > 0:\n                fig, axes = plt.subplots(1, min(3, len(images)), figsize=(15, 5))\n                if len(images) == 1:\n                    axes = [axes]\n                sample_images = random.sample(images, min(3, len(images)))\n                \n                for i, img_path in enumerate(sample_images):\n                    img = cv2.imread(str(img_path))\n                    if img is not None:\n                        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n                        axes[i].imshow(img)\n                        axes[i].set_title(f'{split_name.capitalize()}: {img_path.name}')\n                        axes[i].axis('off')\n                \n                plt.tight_layout()\n                plt.show()\n    \n    # Plot split distribution\n    if split_counts:\n        plt.figure(figsize=(8, 6))\n        colors = ['#2ecc71', '#f39c12', '#e74c3c']\n        valid_splits = [k for k in splits if k in split_counts and split_counts[k] > 0]\n        valid_counts = [split_counts[k] for k in valid_splits]\n        \n        plt.bar(valid_splits, valid_counts, color=colors[:len(valid_splits)])\n        plt.title('Dataset Split Distribution', fontsize=14, fontweight='bold')\n        plt.xlabel('Split')\n        plt.ylabel('Number of Images')\n        for i, (k, v) in enumerate(zip(valid_splits, valid_counts)):\n            plt.text(i, v + 0.5, str(v), ha='center', fontweight='bold')\n        plt.show()\n    \n    return split_counts\n\nsplit_counts = analyze_dataset(dataset_path)\n\n# Step 8: Model Configuration\nprint(\"\\n\" + \"=\"*50)\nprint(\"Model Configuration\")\nprint(\"=\"*50)\n\n# Check if GPU is available\ndevice = 0 if torch.cuda.is_available() else 'cpu'\nprint(f\"\\nUsing device: {device}\")\n\n# Use YOLOv8m for CPU, YOLOv8l for GPU\nif device == 0:  # GPU available\n    model_name = 'yolov8l'\n    print(\"✅ GPU detected - using YOLOv8l